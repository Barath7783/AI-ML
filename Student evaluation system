:- initialization(main).

main :-
    write('Enter Degree (btech/mca/bba): '), read(D),
    write('Enter CGPA: '), read(C),
    career(D, C, R),
    write('Suggested Career: '), write(R), nl.

career(btech, C, 'Software Engineer') :- C >= 8.
career(btech, C, 'Tester') :- C < 8.

career(mca, C, 'Developer') :- C >= 7.5.
career(mca, C, 'Support Engineer') :- C < 7.5.

career(bba, C, 'Manager') :- C >= 7.
career(bba, C, 'Sales Executive') :- C < 7.
