student(divya, 65, 70, 60). 
% -------- Total -------- 
total(Name, Total) :- 
    student(Name, S1, S2, S3), 
    Total is S1 + S2 + S3. 
% -------- Average -------- 
average(Name, Avg) :- 
    total(Name, Total), 
    Avg is Total / 3. 
% -------- Grade -------- 
grade(Name, Grade) :- 
    average(Name, Avg), 
    ( Avg >= 80 -> Grade = 'A' 
    ; Avg >= 60 -> Grade = 'B' 
    ; Avg >= 40 -> Grade = 'C' 
    ; Grade = 'F' 
    ). 
% -------- Result -------- 
result(Name) :- 
    student(Name, S1, S2, S3), 
    total(Name, T), 
    average(Name, A), 
    grade(Name, G), 
    write('Name: '), write(Name), nl, 
    write('Marks: '), write(S1), write(', '), write(S2), write(', '), write(S3), nl, 
    write('Total: '), write(T), nl, 
    write('Average: '), write(A), nl, 
    write('Grade: '), write(G), nl.
