board = [" "] * 9

def show():
    for i in range(0, 9, 3):
        print(board[i], "|", board[i+1], "|", board[i+2])

def win(p):
    w = [(0,1,2),(3,4,5),(6,7,8),
         (0,3,6),(1,4,7),(2,5,8),
         (0,4,8),(2,4,6)]
    return any(board[a]==board[b]==board[c]==p for a,b,c in w)

for t in range(9):
    show()
    m = int(input("Enter position (0-8): "))
    board[m] = "X" if t%2==0 else "O"
    if win(board[m]):
        show()
        print(board[m], "wins!")
        break
